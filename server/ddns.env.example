# Copy to ddns.env and fill these in. Do not commit ddns.env.

# Cloudflare API token with Zone:DNS:Edit and Zone:Zone:Read for this one zone.
CF_API_TOKEN="replace-with-cloudflare-api-token"

# Your Cloudflare zone/root domain, not the subdomain.
CF_ZONE_NAME="example.com"

# The exact DNS record the phone will use.
CF_RECORD_NAME="sms.example.com"

# A is normal for IPv4 home internet. Use AAAA only if you intentionally want IPv6 DDNS.
CF_RECORD_TYPE="A"

# Keep true for the Cloudflare-proxied setup we chose.
CF_RECORD_PROXIED="true"

# 1 means Auto in Cloudflare.
CF_RECORD_TTL="1"

# Public IP detector. Change only if this service is unavailable for you.
CF_IP_SOURCE="https://api.ipify.org"
